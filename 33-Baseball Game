class Solution {
    public int calPoints(String[] operations) {
   Stack<Integer> stack=new Stack<Integer>();
for(String op:operations){

if(op.equals("+")){
int last=stack.pop();
int sum=last+stack.peek();
stack.push(last);
stack.push(sum);
}else if(op.equals("D")){
    stack.push(2*stack.peek());
}else if(op.equals("C")){
    stack.pop();
}else{
    stack.push(Integer.parseInt(op));
}

}
   int total=0;
   for(int num:stack){
  total+=num;

   }
         return total;


    }
}
